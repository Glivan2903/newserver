OPENAI_API_KEY=coloque_sua_chave_aqui
PORT=3000

# Login do painel /admin (leitura dos clientes/testes gerados)
ADMIN_EMAIL=coloque_seu_email_aqui
ADMIN_PASSWORD=coloque_sua_senha_aqui

# Opcional: só necessário em produção (Vercel). Ao conectar um banco Redis
# (KV legado ou integração Upstash Redis) na aba Storage do projeto na Vercel,
# uma dessas duplas de variáveis é injetada automaticamente — não precisa
# preencher à mão. Sem elas, o servidor usa database.json localmente, como sempre.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
